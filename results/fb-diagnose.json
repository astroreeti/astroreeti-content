        {
          "id": "1224808644049541_122094875439410798",
          "message": "\u0915\u0941\u0902\u0921\u0932\u0940 \u092e\u0947\u0902 \u0939\u0930 \u0917\u094d\u0930\u0939 \u0915\u093e \u090f\u0915 \"\u0938\u094d\u0915\u094b\u0930\" \u0939\u094b\u0924\u093e \u0939\u0948 \u2014 \u0914\u0930 \u091c\u093c\u094d\u092f\u093e\u0926\u093e\u0924\u0930 \u0932\u094b\u0917 \u0909\u0938\u0947 \u0926\u0947\u0916\u0924\u0947 \u0939\u0940 \u0928\u0939\u0940\u0902 \ud83d\udcca\u2728\n\n\u0907\u0938\u0947 \u0915\u0939\u0924\u0947 \u0939\u0948\u0902 \u0905\u0937\u094d\u091f\u0915\u0935\u0930\u094d\u0917 \u2014 \u0939\u0930 \u0917\u094d\u0930\u0939 \u0915\u0947 \u0932\u093f\u090f 7 \u0917\u094d\u0930\u0939 + \u0932\u0917\u094d\u0928 (\u0915\u0941\u0932 \u0906\u0920) \u092e\u093f\u0932\u0915\u0930 \u0924\u092f \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0915\u094c\u0928-\u0938\u0940 \u0930\u093e\u0936\u093f \u0909\u0938\u0915\u0947 \u0932\u093f\u090f \u0936\u0941\u092d \u0939\u0948 \u0914\u0930 \u0915\u094c\u0928-\u0938\u0940 \u0928\u0939\u0940\u0902\u0964\n\n\u0907\u0938 \u0921\u0940\u092a-\u0921\u093e\u0907\u0935 \u092e\u0947\u0902 \u091c\u093e\u0928\u093f\u090f:\n\u2726 \u092c\u093f\u0902\u0926\u0941 \u092a\u094d\u0930\u0923\u093e\u0932\u0940 \u2014 \u0939\u0930 \u0930\u093e\u0936\u093f \u092e\u0947\u0902 0 \u0938\u0947 8 \u0915\u093e \u0938\u094d\u0915\u094b\u0930, 4 \u0914\u0938\u0924, 5+ \u092c\u0932\u0935\u093e\u0928\n\u2726 \u0938\u0930\u094d\u0935\u093e\u0937\u094d\u091f\u0915\u0935\u0930\u094d\u0917 (SAV) \u2014 \u0915\u0941\u0932 337 \u092c\u093f\u0902\u0926\u0941, \u0914\u0938\u0924 ~28 \u092a\u094d\u0930\u0924\u093f \u0930\u093e\u0936\u093f, 30+ = \u092e\u091c\u093c\u092c\u0942\u0924 \u0915\u094d\u0937\u0947\u0924\u094d\u0930\n\u2726 \u0917\u094b\u091a\u0930 \u0915\u093e \u0905\u0938\u0932\u0940 \u0928\u093f\u092f\u092e \u2014 \u090f\u0915 \u0939\u0940 \u0936\u0928\u093f \u0915\u093f\u0938\u0940 \u0915\u094b \u0909\u0928\u094d\u0928\u0924\u093f \u0914\u0930 \u0915\u093f\u0938\u0940 \u0915\u094b \u0938\u0902\u0918\u0930\u094d\u0937 \u0915\u094d\u092f\u094b\u0902 \u0926\u0947\u0924\u093e \u0939\u0948\n\u2726 3 \u0906\u0938\u093e\u0928 \u0915\u0926\u092e \u2014 \u0905\u092a\u0928\u0940 \u0915\u0941\u0902\u0921\u0932\u0940 \u0915\u0940 \u0905\u0937\u094d\u091f\u0915\u0935\u0930\u094d\u0917 \u0924\u093e\u0932\u093f\u0915\u093e \u0916\u0941\u0926 \u0915\u0948\u0938\u0947 \u092a\u0922\u093c\u0947\u0902\n\n\u092f\u0939\u0940 \u0935\u091c\u0939 \u0939\u0948 \u0915\u093f \u0938\u093e\u0922\u093c\u0947 \u0938\u093e\u0924\u0940 \u0938\u092c \u092a\u0930 \u090f\u0915-\u0938\u0940 \u0928\u0939\u0940\u0902 \u092c\u0940\u0924\u0924\u0940 \u2014 \u092c\u093f\u0902\u0926\u0941 \u0926\u0947\u0916\u093f\u090f, \u0921\u0930 \u0928\u0939\u0940\u0902 \ud83d\ude4f\n\n\ud83d\udccc \u092f\u0939 \u0930\u0940\u0932 \u0938\u0947\u0935 \u0915\u0930\u0947\u0902 \u2014 \u0905\u0917\u0932\u0940 \u092c\u093e\u0930 \u0915\u094b\u0908 \u092d\u0940 \u0917\u094b\u091a\u0930 \u0926\u0947\u0916\u0924\u0947 \u0938\u092e\u092f \u092f\u0939\u0940 \u0924\u093e\u0932\u093f\u0915\u093e \u0915\u093e\u092e \u0906\u090f\u0917\u0940\n\ud83d\udce4 \u0909\u0938 \u0926\u094b\u0938\u094d\u0924 \u0915\u094b \u092d\u0947\u091c\u0947\u0902 \u091c\u094b \u0938\u093e\u0922\u093c\u0947 \u0938\u093e\u0924\u0940 \u0938\u0947 \u0918\u092c\u0930\u093e\u092f\u093e \u0939\u0941\u0906 \u0939\u0948\n\ud83d\udcac \u0915\u092e\u0947\u0902\u091f \u0915\u0930\u0947\u0902 \"\u0905\u0937\u094d\u091f\u0915\u0935\u0930\u094d\u0917\" \u2014 \u0905\u0917\u0932\u093e \u092d\u093e\u0917 \u0915\u0915\u094d\u0937\u094d\u092f\u093e \u0914\u0930 \u0917\u094b\u091a\u0930 \u0915\u0947 \u0938\u0942\u0915\u094d\u0937\u094d\u092e \u0928\u093f\u092f\u092e \u092a\u0930\n\u2728 \u0924\u0915\u0928\u0940\u0915\u0940 \u091c\u094d\u092f\u094b\u0924\u093f\u0937 \u0939\u0930 \u0938\u092a\u094d\u0924\u093e\u0939 \u2014 \u092b\u093c\u0949\u0932\u094b \u0915\u0930\u0947\u0902 @astroreeti\n\n#\u0935\u0948\u0926\u093f\u0915\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u0905\u0937\u094d\u091f\u0915\u0935\u0930\u094d\u0917 #\u0915\u0941\u0902\u0921\u0932\u0940 #\u0917\u094b\u091a\u0930 #\u0936\u0928\u093f #\u0938\u093e\u0922\u093c\u0947\u0938\u093e\u0924\u0940 #\u092c\u093f\u0902\u0926\u0941 #\u0930\u093e\u0936\u093f\u092b\u0932 #\u091c\u094d\u092f\u094b\u0924\u093f\u0937\u0936\u093e\u0938\u094d\u0924\u094d\u0930 #\u092d\u093e\u0930\u0924\u0940\u092f\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u0917\u094d\u0930\u0939 #\u0930\u093e\u0936\u093f #\u0926\u0936\u093e #\u091c\u094d\u092f\u094b\u0924\u093f\u0937\u0938\u0940\u0916\u0947\u0902 #Ashtakavarga #VedicAstrology #Jyotish #SadeSati #Gochar #astroreeti",
          "permalink_url": "https://www.facebook.com/reel/1693231971719643/",
          "created_time": "2026-07-22T14:48:04+0000",
          "status_type": "added_video"
        },
        {
          "id": "1224808644049541_122094571455410798",
          "message": "\u0915\u0930\u093f\u092f\u0930 \u092f\u093e \u0938\u093f\u0930\u094d\u092b\u093c \u0928\u094c\u0915\u0930\u0940? \ud83c\udf19 \u0906\u092a\u0915\u0940 \u0915\u0941\u0902\u0921\u0932\u0940 \u092e\u0947\u0902 \u0907\u0928 \u0926\u094b\u0928\u094b\u0902 \u0915\u0947 \u0918\u0930 \u0905\u0932\u0917-\u0905\u0932\u0917 \u0939\u0948\u0902\u0964\n\n\u0935\u0948\u0926\u093f\u0915 \u091c\u094d\u092f\u094b\u0924\u093f\u0937 \u092e\u0947\u0902 \u0926\u0938\u0935\u093e\u0901 \u092d\u093e\u0935 \u0915\u0930\u094d\u092e \u092d\u093e\u0935 \u0939\u0948 \u2014 \u0915\u0930\u093f\u092f\u0930, \u092a\u0926 \u0914\u0930 \u092a\u0939\u091a\u093e\u0928\u0964 \u0914\u0930 \u091b\u0920\u093e \u092d\u093e\u0935 \u0939\u0948 \u0928\u094c\u0915\u0930\u0940, \u0938\u0947\u0935\u093e \u0914\u0930 \u0930\u094b\u091c\u093c \u0915\u0947 \u0938\u0902\u0918\u0930\u094d\u0937 \u0915\u093e \u0918\u0930\u0964\n\n\u2726 \u0926\u0936\u092e \u092d\u093e\u0935 \u0914\u0930 \u0909\u0938\u0915\u093e \u0938\u094d\u0935\u093e\u092e\u0940 \u2014 \u0906\u092a\u0915\u0940 \u090a\u0901\u091a\u093e\u0908 \u0924\u092f \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\n\u2726 \u0937\u0937\u094d\u0920 \u092d\u093e\u0935 \u092c\u0932\u0935\u093e\u0928 \u2014 \u0928\u094c\u0915\u0930\u0940 \u092e\u093f\u0932\u0924\u0940 \u092d\u0940 \u0939\u0948, \u091f\u093f\u0915\u0924\u0940 \u092d\u0940 \u0939\u0948\n\u2726 \u0938\u0942\u0930\u094d\u092f \u0914\u0930 \u0936\u0928\u093f \u0915\u0940 \u0938\u094d\u0925\u093f\u0924\u093f \u2014 \u0924\u0930\u0915\u093c\u094d\u0915\u093c\u0940 \u0915\u093e \u0938\u092e\u092f \u092c\u0924\u093e\u0924\u0940 \u0939\u0948\n\n\u0906\u092a\u0915\u0940 \u0915\u0941\u0902\u0921\u0932\u0940 \u092e\u0947\u0902 \u0915\u0930\u093f\u092f\u0930 \u0915\u093e \u0905\u0938\u0932\u0940 \u0930\u093e\u091c\u093c \u0915\u094d\u092f\u093e \u0939\u0948? \u0928\u0940\u091a\u0947 \u0915\u092e\u0947\u0902\u091f \u0915\u0930\u0947\u0902 \"10\" \ud83c\udf19\n\n\ud83d\udccc \u0938\u0947\u0935 \u0915\u0930\u0947\u0902 \u00b7 \ud83d\udce4 \u0936\u0947\u092f\u0930 \u0915\u0930\u0947\u0902\n\u2728 \u0930\u094b\u091c\u093c \u0915\u0947 \u0935\u0948\u0926\u093f\u0915 \u091c\u094d\u091e\u093e\u0928 \u0915\u0947 \u0932\u093f\u090f \u092b\u093c\u0949\u0932\u094b \u0915\u0930\u0947\u0902 @astroreeti\n\n#\u0935\u0948\u0926\u093f\u0915\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u0915\u0941\u0902\u0921\u0932\u0940 #\u0926\u0936\u092e\u092d\u093e\u0935 #\u0915\u0930\u093f\u092f\u0930 #\u0928\u094c\u0915\u0930\u0940 #\u0930\u093e\u0936\u093f\u092b\u0932 #Jyotish #VedicAstrology #Kundli #Astrology #Career #\u091c\u094d\u092f\u094b\u0924\u093f\u0937\u0936\u093e\u0938\u094d\u0924\u094d\u0930 #\u0917\u094d\u0930\u0939 #\u0938\u0942\u0930\u094d\u092f #\u0936\u0928\u093f #\u0915\u0930\u094d\u092e #\u092d\u093e\u0930\u0924\u0940\u092f\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #astroreeti #\u0939\u093f\u0902\u0926\u0940",
          "permalink_url": "https://www.facebook.com/reel/1011655357987180/",
