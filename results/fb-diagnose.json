        {
          "id": "1625445165899742",
          "description": "\u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u0928\u0915\u094d\u0937\u0924\u094d\u0930 \u2014 \u0926\u0947\u0935\u0924\u093e\u0913\u0902 \u0915\u0947 \u0935\u0948\u0926\u094d\u092f \u2728 27 \u0928\u0915\u094d\u0937\u0924\u094d\u0930\u094b\u0902 \u0915\u0940 \u0915\u0925\u093e-\u0936\u094d\u0930\u0943\u0902\u0916\u0932\u093e \u0915\u093e \u092a\u0939\u0932\u093e \u0905\u0927\u094d\u092f\u093e\u092f\u0964\n\n\u092a\u0941\u0930\u093e\u0923\u094b\u0902 \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930 \u0938\u0902\u091c\u094d\u091e\u093e \u0926\u0947\u0935\u0940 \u0928\u0947 \u0918\u094b\u0921\u093c\u0940 \u0915\u093e \u0930\u0942\u092a \u0927\u0930\u093e, \u0938\u0942\u0930\u094d\u092f\u0926\u0947\u0935 \u0905\u0936\u094d\u0935 \u0930\u0942\u092a \u092e\u0947\u0902 \u092a\u0939\u0941\u0901\u091a\u0947 \u2014 \u0914\u0930 \u091c\u0928\u094d\u092e\u0947 \u091c\u0941\u0921\u093c\u0935\u093e\u0902 \u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u0915\u0941\u092e\u093e\u0930, \u091c\u094b \u0909\u0937\u093e \u0938\u0947 \u092a\u0939\u0932\u0947 \u0938\u094d\u0935\u0930\u094d\u0923 \u0930\u0925 \u092a\u0930 \u0906\u0915\u0930 \u0926\u0947\u0935\u0924\u093e\u0913\u0902 \u0915\u093e \u0909\u092a\u091a\u093e\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964\n\n\u0907\u0938 \u0915\u0925\u093e \u092e\u0947\u0902 \u091c\u093e\u0928\u093f\u090f:\n\u2726 \u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u0928\u0915\u094d\u0937\u0924\u094d\u0930 \u0915\u093e \u092a\u0942\u0930\u093e \u092a\u0930\u093f\u091a\u092f \u2014 \u092e\u0947\u0937 0\u00b0\u201313\u00b020\u2032, \u0938\u094d\u0935\u093e\u092e\u0940 \u0915\u0947\u0924\u0941\n\u2726 \u091a\u094d\u092f\u0935\u0928 \u090b\u0937\u093f \u0915\u093e \u092f\u094c\u0935\u0928 \u0914\u0930 \u091a\u094d\u092f\u0935\u0928\u092a\u094d\u0930\u093e\u0936 \u0915\u0940 \u092a\u0930\u0902\u092a\u0930\u093e\n\u2726 \u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u091c\u093e\u0924\u0915 \u0939\u0930 \u0915\u093e\u092e \u092e\u0947\u0902 \u0938\u092c\u0938\u0947 \u0924\u0947\u091c\u093c \u0915\u094d\u092f\u094b\u0902 \u0939\u094b\u0924\u0947 \u0939\u0948\u0902\n\u2726 \u091a\u0902\u0926\u094d\u0930 \u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u092e\u0947\u0902 \u0939\u094b \u0924\u094b \u0915\u094c\u0928-\u0938\u0947 \u0917\u0941\u0923 \u0914\u0930 \u0915\u094c\u0928-\u0938\u0940 \u0938\u0940\u0916\n\n\u0915\u094d\u092f\u093e \u0906\u092a\u0915\u093e \u091c\u0928\u094d\u092e \u0928\u0915\u094d\u0937\u0924\u094d\u0930 \u0905\u0936\u094d\u0935\u093f\u0928\u0940 \u0939\u0948? \u0928\u0940\u091a\u0947 \u0915\u092e\u0947\u0902\u091f \u0915\u0930\u0947\u0902 \"\u0905\u0936\u094d\u0935\u093f\u0928\u0940\" \ud83d\udc0e\n\n\ud83d\udccc \u092f\u0939 \u0915\u0925\u093e \u0938\u0947\u0935 \u0915\u0930\u0947\u0902 \u2014 \u092a\u0942\u0930\u0940 \u0928\u0915\u094d\u0937\u0924\u094d\u0930-\u0936\u094d\u0930\u0943\u0902\u0916\u0932\u093e \u0938\u0902\u092d\u093e\u0932\u0915\u0930 \u0930\u0916\u093f\u090f\n\ud83d\udce4 \u0909\u0938 \u0926\u094b\u0938\u094d\u0924 \u0915\u094b \u092d\u0947\u091c\u0947\u0902 \u091c\u093f\u0938\u0915\u093e \u091a\u0902\u0926\u094d\u0930 \u092e\u0947\u0937 \u0930\u093e\u0936\u093f \u092e\u0947\u0902 \u0939\u0948\n\u2728 \u0939\u0930 \u0938\u092a\u094d\u0924\u093e\u0939 \u0928\u0908 \u0928\u0915\u094d\u0937\u0924\u094d\u0930 \u0915\u0925\u093e \u0915\u0947 \u0932\u093f\u090f \u092b\u093c\u0949\u0932\u094b \u0915\u0930\u0947\u0902 @astroreeti\n\n#\u0935\u0948\u0926\u093f\u0915\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #\u0928\u0915\u094d\u0937\u0924\u094d\u0930 #\u0905\u0936\u094d\u0935\u093f\u0928\u0940 #\u0905\u0936\u094d\u0935\u093f\u0928\u0940\u0928\u0915\u094d\u0937\u0924\u094d\u0930 #\u0905\u0936\u094d\u0935\u093f\u0928\u0940\u0915\u0941\u092e\u093e\u0930 #\u0928\u0915\u094d\u0937\u0924\u094d\u0930\u0915\u0925\u093e #\u0915\u0941\u0902\u0921\u0932\u0940 #\u0930\u093e\u0936\u093f\u092b\u0932 #\u0915\u0947\u0924\u0941 #\u092e\u0947\u0937\u0930\u093e\u0936\u093f #\u091a\u0902\u0926\u094d\u0930\u092e\u093e #\u091c\u0928\u094d\u092e\u0928\u0915\u094d\u0937\u0924\u094d\u0930 #\u092a\u0941\u0930\u093e\u0923 #\u091c\u094d\u092f\u094b\u0924\u093f\u0937\u0936\u093e\u0938\u094d\u0924\u094d\u0930 #\u092d\u093e\u0930\u0924\u0940\u092f\u091c\u094d\u092f\u094b\u0924\u093f\u0937 #Nakshatra #Ashwini #VedicAstrology #Jyotish #astroreeti",
